{
  "name": "Task",
  "type": "object",
  "properties": {
    "plan_id": {
      "type": "string",
      "description": "Reference to Plan"
    },
    "title": {
      "type": "string",
      "description": "Task title"
    },
    "estimated_duration": {
      "type": "number",
      "description": "Total estimated duration in minutes"
    },
    "remaining_duration": {
      "type": "number",
      "description": "Remaining duration in minutes"
    },
    "actual_duration": {
      "type": "number",
      "description": "Total actual time spent in minutes"
    },
    "priority": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ],
      "default": "medium"
    },
    "category": {
      "type": "string",
      "enum": [
        "deep_work",
        "light_task",
        "exercise",
        "meeting",
        "personal"
      ],
      "default": "light_task"
    },
    "deadline": {
      "type": "string",
      "format": "date",
      "description": "Optional deadline date"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "in_progress",
        "completed",
        "deferred"
      ],
      "default": "pending"
    },
    "assigned_date": {
      "type": "string",
      "format": "date",
      "description": "Which date this task session is assigned to"
    },
    "start_time": {
      "type": "string",
      "description": "Scheduled start time HH:mm"
    },
    "end_time": {
      "type": "string",
      "description": "Scheduled end time HH:mm"
    },
    "sort_order": {
      "type": "number",
      "description": "Order within the day"
    },
    "is_split": {
      "type": "boolean",
      "description": "Whether this is a split portion of a larger task",
      "default": false
    },
    "parent_task_id": {
      "type": "string",
      "description": "If split, reference to the original task"
    }
  },
  "required": [
    "title",
    "plan_id"
  ]
}